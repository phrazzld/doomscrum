{
  "name": "specifi-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && npm run build:server",
    "build:server": "node scripts/build-server.mjs",
    "serve": "node build-server/start.js",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "brainrot:generate": "node build-server/generate.js",
    "smoke:provider": "node build-server/generate.js --real-provider",
    "brainrot:report": "node build-server/report.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.560.0",
    "vite": "^7.2.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "typescript-eslint": "^8.50.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
